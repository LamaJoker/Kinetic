{
  "compilerOptions": {
    "target":          "ES2022",
    "module":          "ESNext",
    "moduleResolution": "bundler",
    "lib":             ["ES2022", "DOM", "DOM.Iterable"],
    "strict":          true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride":       true,
    "noImplicitReturns":        true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck":    true,
    "declaration":     true,
    "declarationMap":  true,
    "sourceMap":       true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@kinetic/core":         ["./packages/core/src/index.ts"],
      "@kinetic/adapters-web": ["./packages/adapter-web/src/index.ts"]
    }
  },
  "include": [],
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/adapter-web" },
    { "path": "./apps/web" }
  ]
}