# ══════════════════════════════════════════════════════════════
# Kinetic — Variables d'environnement
#
# USAGE :
#   1. Copier ce fichier : cp .env.example apps/web/.env.local
#   2. Remplir les valeurs Supabase
#   3. Ne JAMAIS committer .env.local
#
# Vercel : Dashboard → Settings → Environment Variables
# ══════════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────────
# Obtenir dans : Supabase Dashboard → Settings → API

# URL de votre projet Supabase
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé publique anonyme (safe à exposer côté client)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── App ──────────────────────────────────────────────────────

# Version de l'app (injectée par CI via git SHA)
VITE_APP_VERSION=1.0.0

# ─── Vercel Edge Functions (serveur uniquement) ───────────────
# NE PAS préfixer par VITE_ — ne doit PAS être exposé au client

# Service Role Key Supabase (pour Edge Functions uniquement)
# Obtenir dans : Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL Supabase (sans VITE_ pour les Edge Functions)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# ─── OAuth (optionnel) ────────────────────────────────────────
# Configurer dans : Supabase → Auth → Providers → Google
# Les credentials OAuth restent dans Supabase, pas dans .env

# ─── Mode dev ─────────────────────────────────────────────────
# En mode dev sans Supabase : laisser les variables vides
# L'app fonctionne en mode "guest" avec IDB local uniquement
